# ─── Required ───────────────────────────────────────
# Auto-generated by setup.sh if left as change-me. Do not ship change-me to prod.
WEBUI_SECRET_KEY=change-me

# ─── Telegram bot (optional) ───────────────────────
# From @BotFather. Leave empty to disable the Telegram bot entirely.
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram IDs allowed to use the bot.
# Empty = bot rejects everyone. Find your ID via @userinfobot.
ALLOWED_TELEGRAM_IDS=

# ─── Tailscale VPN (optional) ──────────────────────
TS_AUTHKEY=

# ─── Models ────────────────────────────────────────
EMBED_MODEL=nomic-embed-text
